# Create/overwrite the root .gitignore
cat > .gitignore << 'EOF'
# Dependencies
node_modules/
apps/web/node_modules/
packages/*/node_modules/
.pnpm-store/

# Next.js
.next/
out/
.turbo/
dist/
build/

# Environment
.env
.env.local
.env.*.local
.env.production
.env.development

# IDE
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# Debug logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
*.log

# Git backup
.git-old/

# TypeScript
*.tsbuildinfo
next-env.d.ts
EOF